<!-- com.local.doh.plist.j2 -->
<plist version="1.0">
<dict>
    <key>Label</key><string>com.local.doh</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{CLOUDFLARED_BIN}}</string>
        <string>proxy-dns</string>
        <string>--address</string><string>{{LISTEN_ADDRESS}}</string>
        <string>--port</string><string>{{LISTEN_PORT}}</string>
{% for upstream in UPSTREAMS %}
        <string>--upstream</string><string>{{upstream}}</string>
{% endfor %}
    </array>

    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>

    <key>StandardOutPath</key>
    <string>{{LOG_PATH}}</string>
    <key>StandardErrorPath</key>
    <string>{{LOG_PATH}}</string>
</dict>
</plist>
